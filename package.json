{
  "name": "pi-extensions",
  "version": "1.0.0",
  "description": "Pi extensions by mibattaglia",
  "keywords": ["pi-package"],
  "scripts": {
    "test": "node --test pi-orchestrator/test/*.test.js",
    "test:orchestrator-smoke": "node --test pi-orchestrator/test/orchestrator-smoke.test.js",
    "test:multitask-no-credit": "node --test pi-orchestrator/test/multitask-no-credit.test.js",
    "test:multitask-real": "PI_MULTITASK_REAL_E2E=1 node --test pi-orchestrator/test/orchestrator-real.test.js"
  },
  "pi": {
    "extensions": [
      "pi-dcg/extensions",
      "pi-web-tools/extensions",
      "pi-ask-question/extensions",
      "pi-orchestrator/extensions",
      "pi-caveman/extensions"
    ],
    "skills": ["pi-caveman/skills"],
    "prompts": ["pi-orchestrator/prompts"]
  }
}
